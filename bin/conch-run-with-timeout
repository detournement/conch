#!/usr/bin/env python3
"""Run `conch-ask` with a timeout."""

from __future__ import annotations

import subprocess
import sys
from pathlib import Path


def main():
    if len(sys.argv) < 3:
        print("usage: conch-run-with-timeout <seconds> <prompt>", file=sys.stderr)
        sys.exit(1)
    timeout = int(sys.argv[1])
    prompt = " ".join(sys.argv[2:])
    ask_path = Path(__file__).resolve().parent / "conch-ask"
    try:
        result = subprocess.run(
            [sys.executable, str(ask_path), prompt],
            capture_output=True,
            text=True,
            timeout=timeout,
        )
    except subprocess.TimeoutExpired:
        print("conch-ask timed out", file=sys.stderr)
        sys.exit(124)
    if result.returncode != 0:
        sys.stderr.write(result.stderr)
        sys.exit(result.returncode)
    sys.stdout.write(result.stdout)


if __name__ == "__main__":
    main()
